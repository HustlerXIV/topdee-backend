BACKEND_PORT=8080
MONGO_URI=mongodb://topdee:topdee@localhost:27017/topdee?authSource=admin
MONGO_DB=topdee
JWT_SECRET=change-me-in-production-please
JWT_TTL_HOURS=24
AI_SERVICE_URL=http://localhost:8000

# Platform agent — applied uniformly to every tenant.
PLATFORM_SYSTEM_PROMPT=You are a helpful, friendly customer support agent. Answer concisely using only the provided knowledge. If the answer is not in the knowledge, say you don't know and offer to connect the customer with a human.
PLATFORM_MODEL=gemini-2.5-flash
PLATFORM_TEMPERATURE=0.3

# ── Facebook Messenger / Login ──────────────────────────────────────────
# App-level identity from your Meta developer console. Used both for webhook
# signature verification and for the Facebook Login OAuth flow that lets
# tenants connect pages from the dashboard.
#
# Per-page access tokens are stored per-connection in Mongo, NOT in env.
FB_APP_ID=
FB_APP_SECRET=
FB_VERIFY_TOKEN=topdee-verify-change-me

# Must EXACTLY match a "Valid OAuth Redirect URI" configured under
# "Facebook Login → Settings" in the Meta console. In production this is
# your public backend URL; locally use ngrok / cloudflared.
FB_OAUTH_REDIRECT_URI=http://localhost:8080/webhooks/facebook/oauth/callback

# Where the OAuth callback redirects the browser after finishing the dance.
# Should be your dashboard origin — the /channels page reads ?fb_oauth=ok&state=...
# off the URL to show the page picker.
FRONTEND_BASE_URL=http://localhost:3000

# Public origin of THIS backend service. Used to build the webhook URLs we
# hand back to customers (e.g. "Paste this into LINE → Webhook URL"):
#   ${BACKEND_PUBLIC_URL}/webhooks/line/<channel_id>
# In production, your real domain. Locally, an ngrok / cloudflared tunnel.
BACKEND_PUBLIC_URL=http://localhost:8080
